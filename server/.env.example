# server/.env.example — Copy thanh .env va sua gia tri

# ── Database (PostgreSQL) ────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=maxhub
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── JWT ──────────────────────────────────────────
JWT_SECRET=change_this_to_random_string
JWT_EXPIRE_HOURS=72

# ── App Version / Auto Update ────────────────────
# Cap nhat sau moi lan build (xem output cua build.py)
APP_VERSION=1.0.0
UPDATE_URL=https://your-domain.com/downloads/Setup_MaxHub_1.0.0.exe
UPDATE_SHA256=
UPDATE_CHANGELOG=Ban cap nhat dau tien.
UPDATE_FORCE=false
UPDATE_FILE_SIZE=0
