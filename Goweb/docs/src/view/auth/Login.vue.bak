<template>
  <lay-config-provider :theme="appStore.theme" :themeVariable="appStore.themeVariable">
    <div class="auth-page">
      <div class="auth-box">
        <div class="auth-left">
          <img src="/icons/duango_logo.png" alt="MaxHub" class="auth-logo" />
          <h2 class="auth-heading">Quản lý thông minh,<br/>Kết nối mọi thứ</h2>
          <p class="auth-desc">Nền tảng quản lý tập trung giúp bạn kiểm soát, tự động hóa và tối ưu hiệu suất làm việc.</p>
          <div class="auth-pills">
            <span class="pill pill-teal">● Realtime Sync</span>
            <span class="pill pill-blue">● AI Powered</span>
            <span class="pill pill-amber">● Enterprise</span>
          </div>
        </div>
        <div class="auth-right">
          <div class="auth-form-wrapper">
            <h2>Đăng nhập</h2>
            <p class="auth-sub">Chào mừng trở lại</p>
            <lay-form :model="form" :pane="true">
              <lay-form-item prop="username">
                <lay-input
                  v-model="form.username"
                  placeholder="Tài khoản"
                  prefix-icon="layui-icon-username"
                  :allow-clear="true"
                  @keyup.enter="focus_password"
                />
              </lay-form-item>
              <lay-form-item prop="password">
                <lay-input
                  ref="passRef"
                  v-model="form.password"
                  type="password"
                  placeholder="Mật khẩu"
                  prefix-icon="layui-icon-password"
                  password
                  @keyup.enter="on_submit"
                />
              </lay-form-item>
              <lay-form-item v-if="error_msg">
                <div class="auth-error">
                  <lay-icon type="layui-icon-close-fill" size="14px" color="#ff5722" />
                  <span>{{ error_msg }}</span>
                </div>
              </lay-form-item>
              <lay-form-item>
                <div class="auth-btn-row">
                  <lay-button
                    type="primary"
                    :loading="loading"
                    size="lg"
                    @click="on_submit"
                  >
                    Đăng nhập
                  </lay-button>
                  <lay-button
                    type="danger"
                    size="lg"
                    @click="on_cancel"
                  >
                    Huỷ
                  </lay-button>
                </div>
              </lay-form-item>
            </lay-form>
            <div class="auth-footer">
              <span>Chưa có tài khoản?</span>
              <router-link to="/register">Đăng ký ngay</router-link>
            </div>
          </div>
        </div>
      </div>
    </div>
  </lay-config-provider>
</template>

<script setup lang="ts">
import { ref, reactive } from "vue";
import { useRouter } from "vue-router";
import { useAuthStore } from "../../store/auth";
import { useAppStore } from "../../store/app";

const router = useRouter();
const auth_store = useAuthStore();
const appStore = useAppStore();
const loading = ref(false);
const error_msg = ref("");
const passRef = ref();

const form = reactive({
  username: "",
  password: "",
});

const focus_password = () => {
  passRef.value?.$el?.querySelector("input")?.focus();
};

const on_cancel = () => {
  form.username = "";
  form.password = "";
  error_msg.value = "";
  router.push("/");
};

const on_submit = async () => {
  if (!form.username || !form.password) {
    error_msg.value = "Vui lòng nhập đầy đủ thông tin";
    return;
  }
  loading.value = true;
  error_msg.value = "";
  try {
    await auth_store.login(form.username, form.password);
    router.push("/");
  } catch (err: any) {
    error_msg.value = err.response?.data?.error || "Đăng nhập thất bại";
  } finally {
    loading.value = false;
  }
};
</script>

<style scoped>
